{
  "name": "ecohabit",
  "version": "0.1.0",
  "private": true,
  "description": "EcoHabit - Gamified Waste Management & Recycling App",
  "workspaces": [
    "apps/*",
    "packages/*",
    "functions/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "firebase:emulators": "firebase emulators:start",
    "firebase:deploy": "firebase deploy",
    "setup": "pnpm install && pnpm build",
    "prepare": "husky install",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:visual": "playwright test tests/visual",
    "test:performance": "playwright test tests/performance",
    "test:accessibility": "playwright test tests/e2e/accessibility",
    "test:3d": "playwright test tests/e2e/3d",
    "test:theme": "playwright test tests/e2e/theme",
    "test:all": "playwright test --reporter=html",
    "test:update-snapshots": "playwright test --update-snapshots",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@playwright/test": "^1.41.2",
    "@axe-core/playwright": "^4.8.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.0.0",
    "playwright": "^1.41.2",
    "prettier": "^3.0.0",
    "turbo": "latest",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
