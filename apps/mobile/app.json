{
  "expo": {
    "name": "EcoHabit",
    "slug": "ecohabit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#22c55e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ecohabit.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#22c55e"
      },
      "package": "com.ecohabit.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#22c55e"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow EcoHabit to access your camera to take photos of your eco-actions."
        }
      ],
      [
        "expo-location",
        {
          "locationPermission": "Allow EcoHabit to access your location to find nearby recycling centers."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
